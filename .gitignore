# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.pytest_cache/
.mypy_cache/

# MUNINN local state (mycelium, ne pas committer)
.muninn/

# Secrets / config locale
.env
*.local.yml
secrets.yml

# Sorties de recon/scan (peuvent contenir des donnees de cibles)
output/
results/
*.recon.json
*.scan.json

# Scopes telecharges (cache local, re-fetchables)
data/programs/*.json
!data/programs/.gitkeep

# Journal des tests : local par securite (peut contenir cibles/findings).
# Retire ces 2 lignes si tu veux versionner ton historique.
journal/*.jsonl
journal/*.log
!journal/.gitkeep

# Engagements : dossiers de travail par programme (données de cible) — local.
engagements/*
!engagements/.gitkeep

# Forge (regression shield) : état local
.forge/

# Bible d'attaque : arsenal perso de techniques (local).
# Retire cette ligne si tu veux la rendre publique (ça aide le portfolio).
attack-bible/

# État généré par le scan matinal (offres/échecs du moment) — transitoire, local.
NOUVELLES_OFFRES.txt
SOURCE_EN_ECHEC.txt
